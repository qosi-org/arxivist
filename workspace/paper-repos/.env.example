# .env.example — copy to .env and fill in as needed.

# Override the default config path used by scripts/*.py if desired.
ARXIVIST_CONFIG_PATH=configs/config.yaml

# Force CPU-only execution even if hardware.device: cuda and a GPU is present.
CUDA_VISIBLE_DEVICES=

# Hugging Face Hub token, only needed if the Chronos-2 checkpoint requires
# authentication to download (Section 5.5).
HF_TOKEN=

# Optional: directory to store large checkpoints/results outside the repo.
ARXIVIST_RESULTS_DIR=results
ARXIVIST_CHECKPOINTS_DIR=checkpoints
